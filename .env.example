# ── Domain (Traefik routing) ──────────────────────────────────────────────
APP_HOST=sentence.valc.cc
APP_WWW_HOST=www.sentence.valc.cc

# ── Images (registry refs you build & push) ───────────────────────────────
# build: docker build -t $SENTENCE_WEB_IMAGE --build-arg VITE_API_URL=https://$APP_HOST/api frontend
SENTENCE_WEB_IMAGE=registry.example.com/sentence-web:latest
# build: docker build -t $SENTENCE_API_IMAGE backend
SENTENCE_API_IMAGE=registry.example.com/sentence-api:latest
# DB uses public mysql:8.4 (schema injected via swarm config). No image var.

# ── Backend secrets / config ──────────────────────────────────────────────
# Required. API crashes on boot without it.
API_KEY_NINJA=

# ── Database ──────────────────────────────────────────────────────────────
MYSQL_ROOT_PASSWORD=change-me
